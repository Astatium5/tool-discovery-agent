<idea-plugin>
    <id>com.tooldiscovery.agent</id>
    <name>Tool Discovery Agent</name>
    <vendor url="https://github.com/your-org/tool-discovery-agent">Tool Discovery</vendor>
    
    <description><![CDATA[
    <p>Tool Discovery Agent for IntelliJ IDEA</p>
    <p>Discovers and interacts with IDE development tools through GUI perception.</p>
    <ul>
        <li>Discover available refactoring and analysis tools</li>
        <li>Plan and execute automated refactoring operations</li>
        <li>Real-time communication with Python agent service</li>
    </ul>
    ]]></description>
    
    <depends>com.intellij.modules.platform</depends>
    
    <!-- Plugin compatibility -->
    <idea-version since-build="223.0"/>
    
    <extensions defaultExtensionNs="com.intellij">
        <!-- Tool Window -->
        <toolWindow id="Tool Discovery"
                    anchor="right"
                    factoryClass="com.tooldiscovery.toolwindow.ToolDiscoveryWindowFactory"
                    icon="AllIcons.General.Modified"/>
        
        <!-- Application Service -->
        <applicationService 
            serviceImplementation="com.tooldiscovery.service.AgentClientService"/>
        
        <!-- Configuration -->
        <applicationConfigurable 
            parentId="tools"
            instance="com.tooldiscovery.service.AgentConfigurable"
            id="com.tooldiscovery.agentConfig"
            displayName="Tool Discovery Agent"/>
    </extensions>
    
    <actions>
        <!-- Main action group -->
        <group id="ToolDiscovery.Actions" text="Tool Discovery" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="first"/>
            
            <action id="ToolDiscovery.Discover"
                    class="com.tooldiscovery.actions.DiscoverToolsAction"
                    text="Discover Tools"
                    description="Discover available IDE tools"
                    icon="AllIcons.Actions.Find"/>
            
            <action id="ToolDiscovery.Connect"
                    class="com.tooldiscovery.actions.ConnectAgentAction"
                    text="Connect to Agent"
                    description="Connect to the Tool Discovery Agent service"
                    icon="AllIcons.General.Add"/>
            
            <separator/>
            
            <action id="ToolDiscovery.Settings"
                    class="com.tooldiscovery.actions.OpenSettingsAction"
                    text="Settings..."
                    description="Open agent settings"
                    icon="AllIcons.General.Settings"/>
        </group>
    </actions>
</idea-plugin>